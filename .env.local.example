# AltoRich — Environment Variables
# Copy to .env.local for local development, or .env.production on cPanel/Namecheap Node hosting.
# NEVER commit files containing real secrets.

# =============================================================================
# REQUIRED — Production
# =============================================================================

# Public site URL (canonical app URL). Used for auth links, SEO, emails.
# Note: this project uses NEXT_PUBLIC_SITE_URL — not NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_SITE_URL=https://altorich.com

# Supabase — PostgreSQL database + Auth (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser bundle
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# OPTIONAL — Email (Resend)
# =============================================================================

# Required for outbound email notifications. Omit to skip email delivery.
# RESEND_API_KEY=re_xxxxxxxx

# =============================================================================
# OPTIONAL — Live chat (Smartsupp)
# =============================================================================

# Public widget key — safe for browser bundles
NEXT_PUBLIC_SMARTSUPP_KEY=c9c2f3f8e32cdb96c278d23abacde841c5e7e2da

# =============================================================================
# OPTIONAL — Feature flags
# =============================================================================

# Enable weekly ROI mode (legacy/alternate investment engine)
# NEXT_PUBLIC_ROI_MODE_ENABLED=true

# =============================================================================
# OPTIONAL — Local development only
# =============================================================================

# Skip device OTP verification during local development
# AUTH_SKIP_DEVICE_OTP=true

# =============================================================================
# OPTIONAL — cPanel / Namecheap Node.js hosting
# =============================================================================

# NODE_ENV=production
# PORT=3000
# HOSTNAME=0.0.0.0
# ALTORICH_ENV_FILE=/home/user/repositories/alto-app/.env.production
# ALTORICH_LOG_DIR=/home/user/logs

# =============================================================================
# NOT USED — Auth is handled by Supabase
# =============================================================================
# AltoRich does not use custom JWT secrets, session secrets, or ADMIN_SECRET.
# Admin access is enforced via Supabase Auth + admin_roles table (RLS + RPC).
