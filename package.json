{
  "name": "altorich",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x || 22.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "start:cpanel": "node server.js",
    "lint": "npm run type-check && npm run lint:eslint",
