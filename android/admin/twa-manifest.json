    },
    {
      "name": "Members",
      "shortName": "Members",
      "url": "/admin-app/members",
      "chosenIconUrl": "https://altorich.com/admin-app/icon-192.png"
    },
    {
      "name": "Deposits",
      "shortName": "Deposits",
      "url": "/admin-app/deposits",
      "chosenIconUrl": "https://altorich.com/admin-app/icon-192.png"
    },
    {
      "name": "Withdrawals",
      "shortName": "Withdrawals",
      "url": "/admin-app/payouts",
      "chosenIconUrl": "https://altorich.com/admin-app/icon-192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://altorich.com/admin-app/manifest.webmanifest",
  "fallbackType": "customtabs",
  "features": {
    "locationDelegation": {
      "enabled": false
    },
    "playBilling": {
