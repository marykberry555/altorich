  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "../signing-key.jks",
    "alias": "altorich-admin"
  },
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "shortcuts": [
    {
      "name": "Dashboard",
      "shortName": "Dashboard",
      "url": "/admin-app",
